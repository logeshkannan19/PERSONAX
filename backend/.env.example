# PERSONAX Backend Environment Configuration

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/personax?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"

# Vector Database (optional - for embeddings)
# PINECONE_API_KEY="your-pinecone-key"
# PINECONE_ENVIRONMENT="us-east-1"
# PINECONE_INDEX="personax"

# Server
PORT=3001
NODE_ENV="development"

# Client URLs (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL="info"

# External Services
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""